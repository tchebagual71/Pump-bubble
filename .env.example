# Pump-bubble DAO Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# NETWORK CONFIGURATION
# ==============================================================================
# Network to use: devnet, testnet, or mainnet-beta
SOLANA_NETWORK=devnet
# Solana RPC endpoint (use Helius, QuickNode, or public RPCs)
SOLANA_RPC_URL=https://api.devnet.solana.com

# ==============================================================================
# PROGRAM ADDRESSES
# ==============================================================================
# Your deployed Anchor program ID (from anchor deploy)
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Squads multisig program ID (v4)
SQUADS_PROGRAM_ID=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf

# SPL Governance program ID
GOVERNANCE_PROGRAM_ID=GovER5Lthms3bLBqWub97yVrMmEogzX7xNjdXpPPCVZw

# ==============================================================================
# DAO INFRASTRUCTURE
# ==============================================================================
# Your Squads multisig address (from create-multisig script)
SQUADS_MULTISIG_ADDRESS=

# Your governance realm address (from create-governance script)
GOVERNANCE_REALM_ADDRESS=

# DAO share token mint address
SHARE_TOKEN_MINT_ADDRESS=

# USDC mint address (different per network)
# Devnet: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ==============================================================================
# TELEGRAM BOT (for bot/ directory)
# ==============================================================================
# Get from @BotFather on Telegram
BOT_TOKEN=

# Bot server port
PORT=3000

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# ==============================================================================
# GRAPE PROTOCOL TOKEN GATING (optional)
# ==============================================================================
# Grape access token mint for membership verification
GRAPE_ACCESS_TOKEN_MINT=

# Minimum token balance required
GRAPE_REQUIRED_AMOUNT=1

# Grape API URL
GRAPE_API_URL=https://api.grap3.io

# Grape API access token (if required)
GRAPE_ACCESS_TOKEN=

# Grape community ID
GRAPE_COMMUNITY_ID=

# ==============================================================================
# JUPITER AGGREGATOR
# ==============================================================================
# Jupiter Quote API endpoint
JUPITER_QUOTE_API=https://quote-api.jup.ag/v6

# Jupiter Swap API endpoint
JUPITER_SWAP_API=https://quote-api.jup.ag/v6/swap

# Default slippage tolerance in basis points (50 = 0.5%)
JUPITER_SLIPPAGE_BPS=50

# ==============================================================================
# DATABASE (for bot/ directory)
# ==============================================================================
# PostgreSQL connection string
DATABASE_URL=postgres://username:password@localhost:5432/pump_bubble

# ==============================================================================
# WALLET CONFIGURATION (for scripts only - DO NOT USE IN PRODUCTION)
# ==============================================================================
# Path to wallet keypair file (for deployment and testing only)
# NEVER commit this file or use production keys in scripts
WALLET_KEYPAIR_PATH=./keypair.json

# For scripts that need a wallet (base58 encoded private key)
# WARNING: This is insecure. Use hardware wallets in production.
# WALLET_PRIVATE_KEY=

# ==============================================================================
# GOVERNANCE CONFIGURATION
# ==============================================================================
# Minimum share tokens required to create a proposal
MIN_TOKENS_TO_CREATE_PROPOSAL=1000000

# Voting period in slots (7200 slots ≈ 1 hour on mainnet)
VOTING_PERIOD_SLOTS=7200

# Vote threshold percentage (60 = 60%)
VOTE_THRESHOLD_PERCENTAGE=60

# ==============================================================================
# MULTISIG CONFIGURATION
# ==============================================================================
# Number of approvals required to execute transactions
MULTISIG_THRESHOLD=2

# Multisig member addresses (comma-separated)
MULTISIG_MEMBERS=

# ==============================================================================
# TRADING LIMITS (optional safety features)
# ==============================================================================
# Maximum trade size as percentage of vault (50 = 50%)
MAX_TRADE_SIZE_PERCENTAGE=50

# Minimum time between trades in seconds
MIN_TRADE_INTERVAL_SECONDS=3600

# Maximum slippage tolerance in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=100

# ==============================================================================
# MONITORING & ALERTS (optional)
# ==============================================================================
# Webhook URL for trade notifications
NOTIFICATION_WEBHOOK_URL=

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Never commit .env files with real credentials
# 2. Use hardware wallets for multisig signers in production
# 3. Test thoroughly on devnet before mainnet deployment
# 4. Set up monitoring for treasury movements
# 5. Regularly backup configuration and multisig info
# 6. Document all program IDs and addresses in your documentation
